<?php
/**
 * Google OAuth – scopes בלבד (אופציונלי, per-environment).
 *
 * העתק ל-google-credentials.php (ב-gitignore). אל תשים כאן Client ID / Secret –
 * הם בדף ההגדרות או ב-wp-config (GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET).
 *
 * ברירת מחדל: CLINIC_QUEUE_DEFAULT_GOOGLE_CALENDAR_SCOPES ב-core/constants.php.
 * דריסה: define('GOOGLE_CALENDAR_SCOPES', '...'); ב-wp-config או להלן.
 *
 * @package ClinicQueue
 */

if (!defined('ABSPATH')) {
    exit;
}

if (!defined('GOOGLE_CALENDAR_SCOPES') && defined('CLINIC_QUEUE_DEFAULT_GOOGLE_CALENDAR_SCOPES')) {
    define('GOOGLE_CALENDAR_SCOPES', CLINIC_QUEUE_DEFAULT_GOOGLE_CALENDAR_SCOPES);
}

// דריסה מקומית (בטל הערה והתאם):
